COMPOSE_PROJECT_NAME=mikept

# Browser-facing ports.
FRONTEND_PORT=3000
BACKEND_PORT=3001
SUPABASE_PORT=54321
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Local Supabase-compatible stack. These values are development-only.
POSTGRES_PASSWORD=local-postgres-password
POSTGRES_DB=postgres
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE3NzgzNzEyMDAsImV4cCI6MjIwODk4ODgwMH0._4sArXe2CskNBPUcNG_ZcrfmxRJx8p-D9rkMIDKYwEQ
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtZGVtbyIsImlhdCI6MTc3ODM3MTIwMCwiZXhwIjoyMjA4OTg4ODAwfQ.cr-pjOpMhI0_ad7N6EkAefeVSyxbQI8-9FAicQJwI0Q

# S3-compatible storage backed by MinIO.
MINIO_ROOT_USER=mikept
MINIO_ROOT_PASSWORD=mikept-local-password
R2_BUCKET_NAME=mike

# Optional cloud model/API keys. Leave blank for Docker boot testing.
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# Optional self-hosted local LLM provider.
# Mike does not start a model server for you. Point this at any
# OpenAI-compatible /v1 endpoint you run yourself, then the UI shows "Local model".
# If the model server runs on the host machine, use host.docker.internal.
ENABLE_LOCAL_LLM=false
LOCAL_LLM_BASE_URL=http://host.docker.internal:1234/v1
LOCAL_LLM_MODEL=
LOCAL_LLM_LABEL=Local model
LOCAL_LLM_API_KEY=
LOCAL_LLM_SUPPORTS_TOOLS=false
LOCAL_LLM_TIMEOUT_MS=120000
